# Declutter — configuration
# Copy this file to .env and adjust to your setup.

# ── Paths ─────────────────────────────────────────────────────────────────────
# Docker: photos are mounted at /photos — always set /photos here
# Without Docker: the path to your photo folder, e.g. /mnt/nas/photos
BASE_DIR=/photos

# Subfolders (relative to BASE_DIR) — change if desired
RAW_DIR=ruwe_data
INBOX_DIR=in_behandeling
ARCHIVE_DIR=verwerkt
TRASH_DIR=prullenbak

# ── Data (Docker) ─────────────────────────────────────────────────────────────
# Folder for cache and app data (thumbnails, recents, log).
# Docker: leave as /data (this is the mounted volume).
# Without Docker: leave empty or set to a writable path.
DATA_DIR=/data

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8765

# ── Immich (optional) ─────────────────────────────────────────────────────────
# A library rescan is triggered automatically after every move.
# Leave empty if you don't use Immich.
IMMICH_URL=http://immich:2283
IMMICH_API_KEY=

# ── Debug ─────────────────────────────────────────────────────────────────────
DEBUG=false
PRESORT_DEBUG=false
