# Declutter — configuratie
# Kopieer dit bestand naar .env en pas aan naar jouw situatie.

# ── Paden ────────────────────────────────────────────────────────────────────
# Docker: foto's worden gemount op /photos — zet hier altijd /photos
# Zonder Docker: het pad naar je fotomap, bijv. /mnt/nas/fotos
BASE_DIR=/photos

# Submappen (relatief aan BASE_DIR) — aanpassen indien gewenst
DUMP_DIR=ruwe_data
UITZOEKEN_DIR=in_behandeling
ARCHIEF_DIR=verwerkt
PRULLENBAK_DIR=prullenbak

# ── Data (Docker) ─────────────────────────────────────────────────────────────
# Map voor cache en app-data (thumbnails, recents, log).
# Docker: laat op /data staan (dit is het gemounte volume).
# Zonder Docker: laat leeg of zet op een schrijfbaar pad.
DATA_DIR=/data

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8765

# ── Immich (optioneel) ───────────────────────────────────────────────────────
# Rescan wordt automatisch getriggerd na elke verplaatsing.
# Laat leeg als je Immich niet gebruikt.
IMMICH_URL=http://immich:2283
IMMICH_API_KEY=

# ── Debug ────────────────────────────────────────────────────────────────────
DEBUG=false
PRESORT_DEBUG=false
